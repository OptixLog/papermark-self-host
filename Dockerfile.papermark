# syntax=docker/dockerfile:1

# ============================================================================
# Papermark Self-Hosted Dockerfile
# ============================================================================
# This Dockerfile builds Papermark, the open-source DocSend alternative
# Based on Next.js with PostgreSQL, S3-compatible storage, and Resend for email
#
# SELF-CONTAINED: the build context is THIS repo. Stage 0 clones the pinned
# upstream papermark source and applies the self-host patches (patches/), so
# any Docker host (CI, Dokploy on-host builds) can build without a separate
# upstream checkout step.
# ============================================================================

ARG NODE_VERSION=20

# ============================================================================
# Stage 0: Upstream source + self-host patches
# ============================================================================
FROM node:${NODE_VERSION}-alpine AS source

RUN apk add --no-cache git

# Pinned: newest public upstream commit that still builds. From 2026-05-05
# (bf2ac83a and later) upstream main imports @/ee/* modules that are NOT in
# the public repo (EE-only: dataroom-trial, branding, request-lists,
# confidential-view, stripe/currency, ...) and `next build` fails on
# module-not-found. Re-audit missing @/ee imports before bumping.
ARG PAPERMARK_REPO=https://github.com/mfts/papermark.git
ARG PAPERMARK_REF=f7a90495a1c2944737f76ed0605450e9e2af532a

WORKDIR /src
RUN git clone --filter=blob:none ${PAPERMARK_REPO} . && \
    git checkout ${PAPERMARK_REF} && \
    rm -rf .git

COPY patches ./patches-selfhost
RUN node patches-selfhost/apply.mjs && rm -rf patches-selfhost

# ============================================================================
# Stage 1: Dependencies
# ============================================================================
FROM node:${NODE_VERSION}-alpine AS deps

RUN apk add --no-cache libc6-compat openssl

WORKDIR /app

# Copy package files
COPY --from=source /src/package.json /src/package-lock.json* /src/yarn.lock* /src/pnpm-lock.yaml* ./
COPY --from=source /src/prisma ./prisma

# Install dependencies based on the preferred package manager
RUN \
  if [ -f yarn.lock ]; then \
    yarn --frozen-lockfile; \
  elif [ -f package-lock.json ]; then \
    npm install || npm ci || true; \
  elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm i --frozen-lockfile; \
  else \
    echo "Lockfile not found." && exit 1; \
  fi



# ============================================================================
# Stage 2: Build
# ============================================================================
FROM node:${NODE_VERSION}-alpine AS builder

WORKDIR /app

# Copy dependencies from deps stage, patched sources from source stage
COPY --from=deps /app/node_modules ./node_modules
COPY --from=source /src .

# Set environment variables for build
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# Generate Prisma Client
RUN npx prisma generate

# NOTE: next.config.docker.js is intentionally NOT copied in. Historically it
# never reached the upstream build context, so the shipped builds always used
# upstream next.config.mjs (non-standalone) — and the runtime start command
# (npx next start) depends on that. Introducing it now would flip the build to
# `output: standalone` and change the runtime contract.

# Build the application
# Note: NEXT_PUBLIC_* vars are INLINED into the client bundle at build time —
# they cannot be changed at runtime. Defaults are the documents.optixlog.com
# deployment; override via build args for other installs.
ARG NEXT_PUBLIC_BASE_URL=https://documents.optixlog.com
ARG NEXT_PUBLIC_APP_BASE_HOST=documents.optixlog.com
ARG NEXT_PUBLIC_MARKETING_URL=https://documents.optixlog.com
# NEXT_PUBLIC_WEBHOOK_BASE_HOST must NEVER equal the app host: the middleware
# treats any request whose Host equals it as an incoming-webhook request and
# 404s every path except /services/* — the whole site goes down. It also must
# not be empty (next.config.mjs uses it in a headers() host matcher and the
# build fails on an undefined value). Use a dedicated subdomain.
ARG NEXT_PUBLIC_WEBHOOK_BASE_HOST=webhooks.documents.optixlog.com
ARG NEXT_PUBLIC_UPLOAD_TRANSPORT=s3
ENV NEXT_PUBLIC_BASE_URL=${NEXT_PUBLIC_BASE_URL}
ENV NEXTAUTH_URL=${NEXT_PUBLIC_BASE_URL}
ENV NEXT_PUBLIC_APP_BASE_HOST=${NEXT_PUBLIC_APP_BASE_HOST}
ENV NEXT_PUBLIC_WEBHOOK_BASE_HOST=${NEXT_PUBLIC_WEBHOOK_BASE_HOST}
ENV NEXT_PUBLIC_MARKETING_URL=${NEXT_PUBLIC_MARKETING_URL}
ENV NEXT_PUBLIC_UPLOAD_TRANSPORT=${NEXT_PUBLIC_UPLOAD_TRANSPORT}
ENV DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy
ENV OPENAI_API_KEY=sk-test12345
ENV HANKO_API_KEY=123dummy
# NEXT_PUBLIC_* is inlined at build time - a dummy here ships "dummy" as the
# tenant_id in the compiled bundle no matter what the runtime env says, and
# Hanko rejects it (tenant_id must be a valid uuid4). The tenant ID is public
# by design (it's in the client JS), so bake the real one.
ARG NEXT_PUBLIC_HANKO_TENANT_ID=bbbe91d0-c7f0-4a08-ba77-10f2d0248e75
ENV NEXT_PUBLIC_HANKO_TENANT_ID=${NEXT_PUBLIC_HANKO_TENANT_ID}
# Self-hosted Trigger.dev instance (realtime progress hooks read this at build time)
ARG NEXT_PUBLIC_TRIGGER_API_URL=https://trigger.optixlog.com
ENV NEXT_PUBLIC_TRIGGER_API_URL=${NEXT_PUBLIC_TRIGGER_API_URL}
ENV SLACK_CLIENT_ID=dummy
ENV SLACK_CLIENT_SECRET=dummy

RUN \
  if [ -f yarn.lock ]; then \
    yarn build; \
  elif [ -f package-lock.json ]; then \
    npm run build; \
  elif [ -f pnpm-lock.yaml ]; then \
    corepack enable pnpm && pnpm build; \
  else \
    echo "Lockfile not found." && exit 1; \
  fi

# ============================================================================
# Stage 3: Production Runtime
# ============================================================================
FROM node:${NODE_VERSION}-alpine AS runner

WORKDIR /app

# Create non-root user for running the app
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Install runtime dependencies
RUN apk add --no-cache \
    libc6-compat \
    openssl \
    curl \
    bash

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# Copy built application
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public

# Copy Prisma schema and migrations
COPY --from=builder /app/prisma ./prisma

# Copy startup script
COPY --chmod=755 <<'EOF' /app/docker-entrypoint.sh
#!/bin/bash
set -e

echo "======================================"
echo "Papermark Self-Hosted Startup"
echo "======================================"

# Wait for database to be ready
if [ -n "$DATABASE_URL" ]; then
    echo "Waiting for database to be ready..."
    max_attempts=30
    attempt=0
    until npx prisma db push --skip-generate || [ $attempt -eq $max_attempts ]; do
        attempt=$((attempt + 1))
        echo "Database not ready, attempt $attempt/$max_attempts..."
        sleep 2
    done
    
    if [ $attempt -eq $max_attempts ]; then
        echo "ERROR: Could not connect to database after $max_attempts attempts"
        exit 1
    fi
    
    echo "✅ Database connection established"
    
    # Run migrations
    echo "Running database migrations..."
    npx prisma db push --skip-generate || true
    #npx prisma migrate deploy || true
    
    echo "✅ Database setup complete"
fi

echo "======================================"
echo "Starting Papermark..."
echo "======================================"

# The upstream build is NOT a standalone output (next.config.docker.js is not
# in the build context), so there is no /app/server.js. Fall back to next start.
if [ -f server.js ]; then
    exec node server.js
else
    exec npx next start -H 0.0.0.0 -p "${PORT:-3000}"
fi
EOF

# Set proper permissions
RUN chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://127.0.0.1:3000/api/health || exit 1

ENTRYPOINT ["/app/docker-entrypoint.sh"]
